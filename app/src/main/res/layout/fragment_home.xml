<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5FF">

    <ScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="260dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Gradient Header -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@drawable/home_header_gradient"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/ourServicesTitle"/>

            <ImageView
                android:id="@+id/locationIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location_pin"
                app:tint="@android:color/white"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="San Francisco, CA"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@+id/locationIcon"
                app:layout_constraintTop_toTopOf="@+id/locationIcon"
                app:layout_constraintBottom_toBottomOf="@+id/locationIcon"/>

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello, John! 👋"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="@+id/locationIcon"
                app:layout_constraintTop_toBottomOf="@+id/locationIcon"/>

            <TextView
                android:id="@+id/serviceQuestionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What service do you need today?"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="@+id/greetingText"
                app:layout_constraintTop_toBottomOf="@+id/greetingText"/>

            <!-- Our Services -->
            <TextView
                android:id="@+id/ourServicesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Services"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:layout_marginStart="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/serviceQuestionText"/>

            <LinearLayout
                android:id="@+id/servicesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@+id/ourServicesTitle">

                <include 
                    android:id="@+id/serviceElectrician"
                    layout="@layout/service_card" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="1dp" />

                <include 
                    android:id="@+id/servicePlumber"
                    layout="@layout/service_card" />

            </LinearLayout>

            <!-- Recent Bookings Section -->
            <TextView
                android:id="@+id/recentBookingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Bookings"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:visibility="visible"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/servicesContainer"/>

            <LinearLayout
                android:id="@+id/recentBookingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@+id/recentBookingsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Dynamic recent bookings will be added here -->

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Swipeable Live Order Tracking -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/activeBookingsViewPager"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginBottom="-4dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bookingIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Indicator Dots -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/bookingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:layout_marginBottom="112dp"
        android:background="@android:color/transparent"
        app:tabBackground="@drawable/tab_indicator_selector"
        app:tabIndicatorHeight="0dp"
        app:tabGravity="center"
        app:tabMaxWidth="12dp"
        app:tabPaddingEnd="6dp"
        app:tabPaddingStart="6dp"
        app:tabRippleColor="@null"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
